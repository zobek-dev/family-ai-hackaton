# Optional overrides for `docker compose ... -f docker-compose.stack.yml`
# Copy to .env (repo root) or merge — most values already live in .env.example

# --- Agent (LangGraph API image) ---
# GEMINI_API_KEY=
# LANGGRAPH_PUBLISH_HOST_PORT=8133

# --- BFF ---
# BFF_PUBLISH_HOST_PORT=4000
# COPILOTKIT_LICENSE_TOKEN=

# --- After `docker compose up`: seed users (org must match composite env) ---
# npm run seed   with:
# INTELLIGENCE_DEFAULT_ORG_ID=hackathon
