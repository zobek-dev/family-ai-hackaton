# ----------------------------------------------------------------------------
# v2a-notion-lead-form/apps/agent/.env — read by `langgraph dev` from this directory.
# Mirrors the keys the agent itself reads at runtime.
# Quickest setup: `cp ../../.env ./.env` from this directory after editing root .env.
# ----------------------------------------------------------------------------

# Gemini Flash-Lite is the default model. Required for chat to work.
# Get a key: https://aistudio.google.com → Get API key (starts with AIza)
# The "stub-..." placeholder lets the agent boot for local dev; chat will fail
# with an opaque auth error until you replace it with a real key.
GEMINI_API_KEY=stub-replace-with-real-key-from-aistudio-google-com

# If you see 503 UNAVAILABLE / "high demand" from Google, wait or switch model here:
# GEMINI_MODEL=gemini-2.0-flash
# GEMINI_MODEL=gemini-2.5-flash
# Default when unset: gemini-3.1-flash-lite

# Agent runtime — pick which model + planner combo runs the agent.
# Options: gemini-flash-deep | gemini-flash-react | claude-sonnet-4-6-react
# See README → "Switching to a different model" for runtime details.
AGENT_RUNTIME=gemini-flash-deep

# IdeaLens graph — defaults to gemini-flash-react so the model reliably calls
# frontend tools (updateWorkspace). DeepAgents often answers with prose only.
# Override to gemini-flash-deep only if you intentionally want the planner.
# IDEALENS_AGENT_RUNTIME=gemini-flash-react

# LangSmith / LangChain tracing — optional. Without a key, leave tracing off to avoid
# “missing LANGSMITH_API_KEY” messages in LangGraph Studio:
LANGCHAIN_TRACING_V2=false
# To enable traces: set LANGCHAIN_TRACING_V2=true and add your key from smith.langchain.com
# LANGSMITH_API_KEY=

# Anthropic key — only needed if AGENT_RUNTIME=claude-sonnet-4-6-react.
# ANTHROPIC_API_KEY=

# Notion integration (required for the lead-form demo)
# Get a token: https://notion.so/my-integrations → New integration → copy the
# "Internal Integration Token". Then SHARE the leads database with that
# integration. The agent calls Notion through `npx @notionhq/notion-mcp-server`.
NOTION_TOKEN=

# Notion Leads database — the source of truth for the canvas.
NOTION_LEADS_DATABASE_ID=
